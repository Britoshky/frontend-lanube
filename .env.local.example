BACKEND_INTERNAL_URL=http://localhost:4003/api/v1
NEXT_PUBLIC_BACKEND_URL=http://localhost:4003/api/v1
# Admin: URLs legacy bajo /rrss/public se reescriben al proxy local /api/editorial/media/...
